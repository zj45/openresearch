{
  "$schema": "https://opencode.ai/desktop-theme.json",
  "name": "Night Owl",
  "id": "nightowl",
  "light": {
    "palette": {
      "neutral": "#f0f0f0",
      "ink": "#403f53",
      "primary": "#4876d6",
      "accent": "#aa0982",
      "success": "#2aa298",
      "warning": "#c96765",
      "error": "#de3d3b",
      "info": "#4876d6",
      "diffAdd": "#2aa298",
      "diffDelete": "#de3d3b"
    },
    "overrides": {
      "syntax-keyword": "#994cc3"
    }
  },
  "dark": {
    "palette": {
      "neutral": "#011627",
      "ink": "#d6deeb",
      "primary": "#82aaff",
      "accent": "#f78c6c",
      "success": "#c5e478",
      "warning": "#ecc48d",
      "error": "#ef5350",
      "info": "#82aaff",
      "diffAdd": "#c5e478",
      "diffDelete": "#ef5350"
    },
    "overrides": {
      "syntax-comment": "#637777",
      "syntax-keyword": "#c792ea",
      "syntax-string": "#ecc48d",
      "syntax-primitive": "#f78c6c"
    }
  }
}
